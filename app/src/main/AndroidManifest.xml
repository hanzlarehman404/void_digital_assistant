<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:description="@string/app_description"
        android:theme="@style/AppTheme"
        android:hardwareAccelerated="true">

        <!-- Launcher screen -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Silently absorbs ASSIST / headphone trigger — finishes immediately -->
        <activity
            android:name=".AssistActivity"
            android:exported="true"
            android:theme="@style/AppTheme.Transparent"
            android:launchMode="singleTask"
            android:taskAffinity="com.void_assistant.assist"
            android:excludeFromRecents="true"
            android:noHistory="true">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.ASSIST" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.VOICE_COMMAND" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!--
            VoiceInteractionService — the entry point Android looks for.
            BIND_VOICE_INTERACTION permission is required so only the OS can bind.
        -->
        <service
            android:name=".VoidVoiceService"
            android:exported="true"
            android:permission="android.permission.BIND_VOICE_INTERACTION">
            <intent-filter>
                <action android:name="android.service.voice.VoiceInteractionService" />
            </intent-filter>
            <meta-data
                android:name="android.voice_interaction"
                android:resource="@xml/voice_interaction_service" />
        </service>

        <!--
            VoiceInteractionSessionService — Android BINDS to this to validate
            the assistant before enabling the Save button.
            Must be exported=true with correct permission.
        -->
        <service
            android:name=".VoidSessionService"
            android:exported="true"
            android:permission="android.permission.BIND_VOICE_INTERACTION_SESSION">
            <intent-filter>
                <action android:name="android.service.voice.VoiceInteractionSessionService" />
            </intent-filter>
        </service>

        <!--
            RecognitionService stub — required by voice_interaction_service.xml.
            Android checks this exists; it does not need to do real speech recognition.
        -->
        <service
            android:name=".VoidRecognitionService"
            android:exported="true"
            android:permission="android.permission.BIND_VOICE_INTERACTION">
            <intent-filter>
                <action android:name="android.speech.RecognitionService" />
            </intent-filter>
        </service>

    </application>
</manifest>
