<?xml version="1.0" encoding="utf-8"?>
<!--
  Required metadata for VoiceInteractionService.
  sessionService points to our no-op session handler.
  recognitionService is omitted — we don't do speech recognition.
-->
<voice-interaction-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:sessionService="com.void_assistant.VoidSessionService"
    android:supportsAssist="true"
    android:supportsLaunchVoiceAssistFromKeyguard="false"
    android:supportsLocalInteraction="false" />
